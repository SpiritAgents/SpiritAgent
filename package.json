{
  "name": "@spirit-agent/dev-root",
  "private": true,
  "description": "Spirit Agent — root scripts for TS build + Rust CLI",
  "workspaces": [
    "packages/*",
    "apps/desktop"
  ],
  "scripts": {
    "build:agent-core": "npm --prefix packages/agent-core run build",
    "build:host-internal": "npm --prefix packages/host-internal run build",
    "build:desktop": "npm --prefix apps/desktop run build",
    "build:acp-server": "npm --prefix packages/acp-server run build",
    "build": "npm run build:agent-core && npm run build:host-internal && npm run build:acp-server && npm run build:desktop",
    "release:verify-version": "node scripts/release/verify-version.mjs",
    "release:cli:bundle": "node scripts/release/bundle-cli.mjs",
    "release:checksums": "node scripts/release/checksums.mjs",
    "release:desktop": "npm --prefix apps/desktop run dist",
    "eval:compare": "npm run build:agent-core && npm run build:host-internal && node scripts/eval-compare.mjs",
    "eval:judge": "npm run build:agent-core && node scripts/eval-judge.mjs",
    "smoke:host-internal-models-parse": "npm --prefix packages/host-internal run smoke:openai-models-parse",
    "dev": "npm run build:agent-core && npm run build:host-internal && cargo run -p spirit-agent",
    "dev:cli": "cargo run -p spirit-agent",
    "dev:desktop": "npm --prefix apps/desktop run dev",
    "dev:desktop:web": "npm --prefix apps/desktop run dev:web"
  },
  "engines": {
    "node": ">=22"
  }
}
