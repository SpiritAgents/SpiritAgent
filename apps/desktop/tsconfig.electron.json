{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist-electron",
    "rootDir": ".",
    "noEmit": false,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo-electron"
  },
  "include": [
    "electron/**/*.ts",
    "src/env.d.ts",
    "src/host/**/*.ts",
    "src/lib/composer-draft-store.ts",
    "src/lib/conversation-thinking-ui.ts",
    "src/lib/conversation-compaction-ui.ts",
    "src/lib/subagent-display.ts",
    "src/lib/git-changes-menu-items.ts",
    "src/lib/fork-session-utils.ts",
    "src/lib/tool-call-shimmer.ts",
    "src/lib/todo-tool-display.ts",
    "src/lib/grep-tool-display.ts",
    "src/lib/tool-verb-context.ts",
    "src/lib/i18n-host.ts",
    "src/lib/spirit-notification-protocol.ts",
    "src/lib/windows-jump-list-build.ts",
    "electron/sync-windows-jump-list.ts",
    "src/types.ts"
  ],
  "exclude": ["electron/preload.ts"]
}