{
  "name": "@spirit-agent/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 1420",
    "dev:electron": "npm run build:electron && wait-on tcp:127.0.0.1:1420 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:1420 electron dist-electron/electron/main.js",
    "dev:web": "concurrently -k -n host,renderer \"npm run dev:web:host\" \"npm run dev:web:renderer\"",
    "dev:web:host": "npm run build:electron && node dist-electron/electron/web-host.js",
    "dev:web:renderer": "vite --host 127.0.0.1 --port 5173",
    "build": "npm --prefix ../../packages/agent-core run build && npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "electron dist-electron/electron/main.js"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@spirit-agent/agent-core": "file:../../packages/agent-core",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.4.0",
    "spirit-agent-repo": "file:../..",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.3",
    "vite": "^8.0.9",
    "wait-on": "^9.0.1"
  }
}
