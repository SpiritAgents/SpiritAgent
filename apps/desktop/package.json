{
  "name": "@spirit-agent/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:deps": "npm run build:host-internal && npm --prefix ../../packages/agent-core run build",
    "dev": "npm run build:deps && npm run build:electron && concurrently -k -n renderer,electron \"npm run dev:renderer\" \"npm run dev:electron:run\"",
    "dev:renderer": "vite --strictPort --host 127.0.0.1 --port 1420",
    "dev:electron": "npm run build:deps && npm run build:electron && wait-on tcp:127.0.0.1:1420 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:1420 electron dist-electron/electron/main.js",
    "dev:electron:run": "wait-on tcp:127.0.0.1:1420 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:1420 electron dist-electron/electron/main.js",
    "dev:web": "npm run build:deps && npm run build:electron && concurrently -k -n host,renderer \"npm run dev:web:host\" \"npm run dev:web:renderer\"",
    "dev:web:host": "node dist-electron/electron/web-host.js",
    "dev:web:renderer": "vite --host 127.0.0.1 --port 5173",
    "build:host-internal": "npm --prefix ../../packages/host-internal run build",
    "build": "npm run build:deps && npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc --noEmit && vite build",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.cjs.json && node ./scripts/rename-preload-to-cjs.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "electron dist-electron/electron/main.js",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production",
    "rebuild:pty": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@napi-rs/keyring": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@spirit-agent/agent-core": "file:../../packages/agent-core",
    "@spirit-agent/host-internal": "file:../../packages/host-internal",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "koffi": "^2.16.1",
    "lucide-react": "^1.8.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.4.0",
    "spirit-agent-repo": "file:../..",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.8.6",
    "license-checker-rseidelsohn": "^4.4.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.3",
    "vite": "^8.0.9",
    "wait-on": "^9.0.1"
  }
}
