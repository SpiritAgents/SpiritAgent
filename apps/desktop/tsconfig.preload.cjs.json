{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist-electron/electron",
    "rootDir": "./electron",
    "noEmit": false,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo-preload"
  },
  "include": ["electron/preload.ts"]
}
