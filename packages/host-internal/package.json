{
  "name": "@spirit-agent/host-internal",
  "version": "0.1.0",
  "private": true,
  "description": "Internal TypeScript host implementation boundaries for Spirit Agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery.d.ts",
      "default": "./dist/discovery.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:openai-models-parse": "npm run build && node dist/smoke/openai-models-parse-smoke.js",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "spirit-agent-repo": "file:../.."
  }
}
