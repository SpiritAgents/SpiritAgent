{
  "name": "@spirit-agent/host-internal",
  "version": "0.1.0",
  "private": true,
  "description": "Internal TypeScript host implementation boundaries for Spirit Agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./discovery": {
      "types": "./dist/discovery.d.ts",
      "default": "./dist/discovery.js"
    },
    "./model-provider-presets": {
      "types": "./dist/model-provider-presets.d.ts",
      "default": "./dist/model-provider-presets.js"
    },
    "./openai-models": {
      "types": "./dist/openai-models.d.ts",
      "default": "./dist/openai-models.js"
    },
    "./reasoning-effort": {
      "types": "./dist/reasoning-effort.d.ts",
      "default": "./dist/reasoning-effort.js"
    },
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "default": "./dist/extensions.js"
    },
    "./marketplace": {
      "types": "./dist/marketplace.d.ts",
      "default": "./dist/marketplace.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    },
    "./workspace-file-reference-query": {
      "types": "./dist/workspace-file-reference-query.d.ts",
      "default": "./dist/workspace-file-reference-query.js"
    },
    "./workspace-file-references": {
      "types": "./dist/workspace-file-references.d.ts",
      "default": "./dist/workspace-file-references.js"
    },
    "./lsp": {
      "types": "./dist/lsp/index.d.ts",
      "default": "./dist/lsp/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm --prefix ../agent-core run build && npm run build:tsc",
    "build:tsc": "tsc -p tsconfig.json",
    "test:workspace-file-references": "npm run build && node --test dist/workspace-file-references.test.js",
    "test:lsp": "npm run build && node --test dist/lsp/providers.test.js dist/lsp/resolve-server.test.js dist/lsp/install.test.js dist/lsp/orchestrator.test.js dist/lsp/service-probe.test.js dist/lsp/write-append.test.js",
    "smoke:lsp": "npm run build && node dist/smoke/lsp-typescript-smoke.js",
    "typecheck": "npm --prefix ../agent-core run build && tsc -p tsconfig.json --noEmit",
    "smoke:openai-models-parse": "npm run build && node dist/smoke/openai-models-parse-smoke.js",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@spirit-agent/agent-core": "file:../agent-core",
    "fflate": "^0.8.2",
    "glob": "^13.0.6",
    "ignore": "^5.3.2",
    "spirit-agent-repo": "file:../..",
    "tar": "^7.5.13",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
