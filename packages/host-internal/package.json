{
  "name": "@spirit-agent/host-internal",
  "version": "0.2.6",
  "description": "Internal TypeScript host implementation boundaries for Spirit Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpiritAgents/SpiritAgent.git",
    "directory": "packages/host-internal"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./default-terminal-shell": {
      "types": "./dist/default-terminal-shell.d.ts",
      "default": "./dist/default-terminal-shell.js"
    },
    "./discovery": {
      "types": "./dist/discovery.d.ts",
      "default": "./dist/discovery.js"
    },
    "./model-provider-presets": {
      "types": "./dist/model-provider-presets.d.ts",
      "default": "./dist/model-provider-presets.js"
    },
    "./openai-models": {
      "types": "./dist/openai-models.d.ts",
      "default": "./dist/openai-models.js"
    },
    "./openai-api-base": {
      "types": "./dist/openai-api-base.d.ts",
      "default": "./dist/openai-api-base.js"
    },
    "./bedrock-region": {
      "types": "./dist/bedrock-region.d.ts",
      "default": "./dist/bedrock-region.js"
    },
    "./azure-resource": {
      "types": "./dist/azure-resource.d.ts",
      "default": "./dist/azure-resource.js"
    },
    "./bedrock-mantle": {
      "types": "./dist/bedrock-mantle.d.ts",
      "default": "./dist/bedrock-mantle.js"
    },
    "./google-vertex-endpoints": {
      "types": "./dist/google-vertex-endpoints.d.ts",
      "default": "./dist/google-vertex-endpoints.js"
    },
    "./reasoning-effort": {
      "types": "./dist/reasoning-effort.d.ts",
      "default": "./dist/reasoning-effort.js"
    },
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "default": "./dist/extensions.js"
    },
    "./marketplace": {
      "types": "./dist/marketplace.d.ts",
      "default": "./dist/marketplace.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "default": "./dist/storage.js"
    },
    "./skill-paths": {
      "types": "./dist/skill-paths.d.ts",
      "default": "./dist/skill-paths.js"
    },
    "./tool-output-archive-path": {
      "types": "./dist/tool-output-archive-path.d.ts",
      "default": "./dist/tool-output-archive-path.js"
    },
    "./image-file-support": {
      "types": "./dist/image-file-support.d.ts",
      "default": "./dist/image-file-support.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    },
    "./workspace-file-reference-query": {
      "types": "./dist/workspace-file-reference-query.d.ts",
      "default": "./dist/workspace-file-reference-query.js"
    },
    "./workspace-file-references": {
      "types": "./dist/workspace-file-references.d.ts",
      "default": "./dist/workspace-file-references.js"
    },
    "./github-pull-request-url": {
      "types": "./dist/github/pull-request-url.d.ts",
      "default": "./dist/github/pull-request-url.js"
    },
    "./github-pull-request-checks-pages": {
      "types": "./dist/github/pull-request-checks-pages.d.ts",
      "default": "./dist/github/pull-request-checks-pages.js"
    },
    "./github-pull-request-conversation-pages": {
      "types": "./dist/github/pull-request-conversation-pages.d.ts",
      "default": "./dist/github/pull-request-conversation-pages.js"
    },
    "./lsp": {
      "types": "./dist/lsp/index.d.ts",
      "default": "./dist/lsp/index.js"
    }
  },
  "files": [
    "dist",
    "built-in-skills",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm --prefix ../agent-core run build && npm run build:tsc",
    "build:tsc": "tsc -p tsconfig.json",
    "test:workspace-file-references": "npm run build && node --test dist/workspace-file-references.test.js",
    "test:lsp": "npm run build && node --test dist/lsp/providers.test.js dist/lsp/resolve-server.test.js dist/lsp/resolve-server-jdtls.test.js dist/lsp/install.test.js dist/lsp/orchestrator.test.js dist/lsp/ready-providers.test.js dist/lsp/service-probe.test.js dist/lsp/write-append.test.js",
    "smoke:lsp": "npm run build && node dist/smoke/lsp-typescript-smoke.js",
    "typecheck": "npm --prefix ../agent-core run build && tsc -p tsconfig.json --noEmit",
    "smoke:openai-models-parse": "npm run build && node dist/smoke/openai-models-parse-smoke.js && node --test dist/bedrock-models.test.js dist/google-vertex-endpoints.test.js dist/google-vertex-models.test.js",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production",
    "prepublishOnly": "npm run build && node ../../scripts/npm/assert-no-file-deps.mjs"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.6.0",
    "@types/turndown": "^5.0.6",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1068.0",
    "@mozilla/readability": "^0.6.0",
    "@spirit-agent/core": "0.2.6",
    "@vscode/ripgrep": "^1.18.0",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.2",
    "glob": "^13.0.6",
    "google-auth-library": "^10.6.1",
    "ignore": "^5.3.2",
    "jsdom": "^29.1.1",
    "tar": "^7.5.13",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
