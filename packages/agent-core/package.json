{
  "name": "@spirit-agent/core",
  "version": "0.2.6",
  "description": "TypeScript core runtime for Spirit Agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N123999/SpiritAgent.git",
    "directory": "packages/agent-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reasoning-effort": {
      "types": "./dist/reasoning-effort.d.ts",
      "default": "./dist/reasoning-effort.js"
    },
    "./model-display-name": {
      "types": "./dist/model-display-name.d.ts",
      "default": "./dist/model-display-name.js"
    },
    "./shell-tool-result": {
      "types": "./dist/shell-tool-result.d.ts",
      "default": "./dist/shell-tool-result.js"
    },
    "./code-completion-to-monaco": {
      "types": "./dist/code-completion/to-monaco.d.ts",
      "default": "./dist/code-completion/to-monaco.js"
    },
    "./code-completion-delete-diff": {
      "types": "./dist/code-completion/delete-diff-preview.d.ts",
      "default": "./dist/code-completion/delete-diff-preview.js"
    },
    "./azure-resource": {
      "types": "./dist/azure-resource.d.ts",
      "default": "./dist/azure-resource.js"
    },
    "./host-bridge": {
      "types": "./dist/host-bridge-public.d.ts",
      "default": "./dist/host-bridge-public.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build && node ../../scripts/npm/assert-no-file-deps.mjs",
    "smoke:contract": "npm run build && node dist/smoke/contract/ai-sdk-openai-smoke.js && node dist/smoke/contract/ai-sdk-openai-json-schema-smoke.js && node dist/smoke/contract/ai-sdk-openai-streaming-smoke.js && node dist/smoke/contract/ai-sdk-openai-stream-reasoning-only-smoke.js && node dist/smoke/contract/ai-sdk-deepseek-streaming-smoke.js && node dist/smoke/contract/ai-sdk-anthropic-streaming-smoke.js && node dist/smoke/contract/ai-sdk-bedrock-streaming-smoke.js && node dist/smoke/contract/ai-sdk-google-streaming-smoke.js && node dist/smoke/contract/ai-sdk-google-vertex-streaming-smoke.js && node dist/smoke/contract/ai-sdk-open-responses-smoke.js && node dist/smoke/contract/ai-sdk-openai-responses-smoke.js && node dist/smoke/contract/ai-sdk-openai-apply-patch-smoke.js && node dist/smoke/contract/ai-sdk-gateway-apply-patch-smoke.js && node dist/smoke/contract/ai-sdk-gateway-web-search-smoke.js && node dist/smoke/contract/ai-sdk-openrouter-apply-patch-smoke.js && node dist/smoke/contract/ai-sdk-open-responses-streaming-smoke.js && node dist/smoke/contract/ai-sdk-alibaba-built-in-tools-smoke.js",
    "smoke:runtime": "npm run build && node dist/smoke/runtime/ai-sdk-openai-runtime-smoke.js && node dist/smoke/runtime/runtime-parity-smoke.js",
    "smoke:host-config": "npm run build && node dist/smoke/host-config/mcp-missing-env-smoke.js",
    "smoke:lsp": "npm --prefix ../host-internal run smoke:lsp",
    "smoke:offline": "npm run smoke:contract && npm run smoke:runtime && npm run smoke:host-config",
    "smoke:live": "npm run smoke:live:openai-compatible",
    "smoke:live:anthropic": "npm run build && node dist/smoke/live/ai-sdk-anthropic-live-smoke.js",
    "smoke:live:bedrock": "npm run build && node dist/smoke/live/ai-sdk-bedrock-live-smoke.js",
    "smoke:live:openai-compatible": "npm run build && node dist/smoke/live/ai-sdk-openai-compatible-live-smoke.js",
    "eval:scenario:validate": "npm run build && node dist/eval/validate-scenario.js",
    "eval:compare:dry-run": "npm run build && node dist/eval/compare-dry-run.js",
    "smoke:ai-sdk:openai:runtime": "npm run build && node dist/smoke/runtime/ai-sdk-openai-runtime-smoke.js",
    "smoke:ai-sdk:openai": "npm run build && node dist/smoke/contract/ai-sdk-openai-smoke.js",
    "smoke:ai-sdk:openai:json-schema": "npm run build && node dist/smoke/contract/ai-sdk-openai-json-schema-smoke.js",
    "smoke:ai-sdk:openai:streaming": "npm run build && node dist/smoke/contract/ai-sdk-openai-streaming-smoke.js",
    "smoke:ai-sdk:openai:stream-reasoning-only": "npm run build && node dist/smoke/contract/ai-sdk-openai-stream-reasoning-only-smoke.js",
    "smoke:ai-sdk:deepseek:streaming": "npm run build && node dist/smoke/contract/ai-sdk-deepseek-streaming-smoke.js",
    "smoke:ai-sdk:openai:all": "npm run smoke:ai-sdk:openai && npm run smoke:ai-sdk:openai:streaming && npm run smoke:ai-sdk:openai:stream-reasoning-only",
    "smoke:ai-sdk:anthropic:streaming": "npm run build && node dist/smoke/contract/ai-sdk-anthropic-streaming-smoke.js",
    "smoke:ai-sdk:open-responses": "npm run build && node dist/smoke/contract/ai-sdk-open-responses-smoke.js",
    "smoke:ai-sdk:openai-responses": "npm run build && node dist/smoke/contract/ai-sdk-openai-responses-smoke.js",
    "smoke:ai-sdk:open-responses:streaming": "npm run build && node dist/smoke/contract/ai-sdk-open-responses-streaming-smoke.js",
    "smoke:runtime:parity": "npm run build && node dist/smoke/runtime/runtime-parity-smoke.js",
    "smoke:mcp:missing-env": "npm run build && node dist/smoke/host-config/mcp-missing-env-smoke.js",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.22",
    "@ai-sdk/amazon-bedrock": "^4.0.117",
    "@ai-sdk/anthropic": "^2.0.79",
    "@ai-sdk/azure": "^3.0.74",
    "@ai-sdk/deepseek": "^2.0.32",
    "@ai-sdk/gateway": "^3.0.121",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/google-vertex": "^3.0.142",
    "@ai-sdk/moonshotai": "^2.0.23",
    "@ai-sdk/open-responses": "^1.0.16",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@ai-sdk/xai": "^3.0.93",
    "@aws/bedrock-token-generator": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.175",
    "undici": "^7.27.2"
  }
}
