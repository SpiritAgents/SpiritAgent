{
  "name": "@spirit-agent/agent-core",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript core runtime for Spirit Agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reasoning-effort": {
      "types": "./dist/reasoning-effort.d.ts",
      "default": "./dist/reasoning-effort.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:contract": "npm run build && node dist/smoke/contract/ai-sdk-openai-smoke.js && node dist/smoke/contract/ai-sdk-openai-json-schema-smoke.js && node dist/smoke/contract/ai-sdk-openai-streaming-smoke.js && node dist/smoke/contract/ai-sdk-openai-stream-reasoning-only-smoke.js && node dist/smoke/contract/ai-sdk-deepseek-streaming-smoke.js && node dist/smoke/contract/ai-sdk-anthropic-streaming-smoke.js",
    "smoke:runtime": "npm run build && node dist/smoke/runtime/ai-sdk-openai-runtime-smoke.js && node dist/smoke/runtime/runtime-parity-smoke.js",
    "smoke:host-config": "npm run build && node dist/smoke/host-config/mcp-missing-env-smoke.js",
    "smoke:offline": "npm run smoke:contract && npm run smoke:runtime && npm run smoke:host-config",
    "smoke:live": "npm run smoke:live:openai-compatible",
    "smoke:live:anthropic": "npm run build && node dist/smoke/live/ai-sdk-anthropic-live-smoke.js",
    "smoke:live:openai-compatible": "npm run build && node dist/smoke/live/ai-sdk-openai-compatible-live-smoke.js",
    "eval:scenario:validate": "npm run build && node dist/eval/validate-scenario.js",
    "eval:compare:dry-run": "npm run build && node dist/eval/compare-dry-run.js",
    "smoke:ai-sdk:openai:runtime": "npm run build && node dist/smoke/runtime/ai-sdk-openai-runtime-smoke.js",
    "smoke:ai-sdk:openai": "npm run build && node dist/smoke/contract/ai-sdk-openai-smoke.js",
    "smoke:ai-sdk:openai:json-schema": "npm run build && node dist/smoke/contract/ai-sdk-openai-json-schema-smoke.js",
    "smoke:ai-sdk:openai:streaming": "npm run build && node dist/smoke/contract/ai-sdk-openai-streaming-smoke.js",
    "smoke:ai-sdk:openai:stream-reasoning-only": "npm run build && node dist/smoke/contract/ai-sdk-openai-stream-reasoning-only-smoke.js",
    "smoke:ai-sdk:deepseek:streaming": "npm run build && node dist/smoke/contract/ai-sdk-deepseek-streaming-smoke.js",
    "smoke:ai-sdk:openai:all": "npm run smoke:ai-sdk:openai && npm run smoke:ai-sdk:openai:streaming && npm run smoke:ai-sdk:openai:stream-reasoning-only",
    "smoke:ai-sdk:anthropic:streaming": "npm run build && node dist/smoke/contract/ai-sdk-anthropic-streaming-smoke.js",
    "smoke:runtime:parity": "npm run build && node dist/smoke/runtime/runtime-parity-smoke.js",
    "smoke:mcp:missing-env": "npm run build && node dist/smoke/host-config/mcp-missing-env-smoke.js",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "^1.0.22",
    "@ai-sdk/anthropic": "^2.0.79",
    "@ai-sdk/deepseek": "^2.0.32",
    "@ai-sdk/openai-compatible": "^2.0.46",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.175"
  }
}
