{
  "name": "@spirit-agent/agent-core",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript core runtime for Spirit Agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:openai": "npm run build && node dist/smoke/openai-smoke.js",
    "smoke:openai:roundtrip": "npm run build && node dist/smoke/openai-roundtrip-smoke.js",
    "smoke:openai:compact": "npm run build && node dist/smoke/openai-compact-smoke.js",
    "smoke:openai:all": "npm run smoke:openai && npm run smoke:openai:roundtrip && npm run smoke:openai:compact"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^25.5.2"
  },
  "dependencies": {
    "openai": "^6.34.0"
  }
}
