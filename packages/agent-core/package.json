{
  "name": "@spirit-agent/agent-core",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript core runtime for Spirit Agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:openai": "npm run build && node dist/smoke/openai-smoke.js",
    "smoke:openai:roundtrip": "npm run build && node dist/smoke/openai-roundtrip-smoke.js",
    "smoke:openai:compact": "npm run build && node dist/smoke/openai-compact-smoke.js",
    "smoke:openai:stream-empty": "npm run build && node dist/smoke/openai-stream-empty-smoke.js",
    "smoke:openai:streaming": "npm run build && node dist/smoke/openai-streaming-smoke.js",
    "smoke:openai:runtime": "npm run build && node dist/smoke/openai-runtime-smoke.js",
    "smoke:runtime:parity": "npm run build && node dist/smoke/runtime-parity-smoke.js",
    "smoke:mcp:missing-env": "npm run build && node dist/smoke/mcp-missing-env-smoke.js",
    "smoke:openai:all": "npm run smoke:openai && npm run smoke:openai:roundtrip && npm run smoke:openai:compact && npm run smoke:openai:stream-empty && npm run smoke:openai:streaming && npm run smoke:openai:runtime",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openai": "^6.34.0"
  }
}
