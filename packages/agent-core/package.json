{
  "name": "@spirit-agent/agent-core",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript core runtime for Spirit Agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:ai-sdk:openai:runtime": "npm run build && node dist/smoke/ai-sdk-openai-runtime-smoke.js",
    "smoke:ai-sdk:openai": "npm run build && node dist/smoke/ai-sdk-openai-smoke.js",
    "smoke:ai-sdk:openai:json-schema": "npm run build && node dist/smoke/ai-sdk-openai-json-schema-smoke.js",
    "smoke:ai-sdk:openai:streaming": "npm run build && node dist/smoke/ai-sdk-openai-streaming-smoke.js",
    "smoke:ai-sdk:openai:stream-reasoning-only": "npm run build && node dist/smoke/ai-sdk-openai-stream-reasoning-only-smoke.js",
    "smoke:ai-sdk:deepseek:streaming": "npm run build && node dist/smoke/ai-sdk-deepseek-streaming-smoke.js",
    "smoke:ai-sdk:openai:all": "npm run smoke:ai-sdk:openai && npm run smoke:ai-sdk:openai:streaming && npm run smoke:ai-sdk:openai:stream-reasoning-only",
    "smoke:runtime:parity": "npm run build && node dist/smoke/runtime-parity-smoke.js",
    "smoke:mcp:missing-env": "npm run build && node dist/smoke/mcp-missing-env-smoke.js",
    "notice": "node scripts/gen-notice.mjs",
    "notice:production": "node scripts/gen-notice.mjs --production"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "license-checker-rseidelsohn": "^4.4.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.32",
    "@ai-sdk/openai": "^3.0.60",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.175",
    "spirit-agent-repo": "file:../.."
  }
}
